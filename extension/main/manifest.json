{
  "manifest_version": 3,
  "name": "AI Knowledge Saver",
  "description": "Quickly save the current page (articles, tweets, videos) to the AI Knowledge Saver backend.",
  "version": "2.0.0",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Save to AI Knowledge Saver"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "permissions": [
    "activeTab",
    "tabs",
    "storage",
    "contextMenus",
    "notifications"
  ],
  "host_permissions": [
    "http://localhost:4000/*",
    "https://api.yoursite.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["contentScript.js"],
      "run_at": "document_idle"
    }
  ]
}